# Environment Variables for Jarvis Home Automation
# Copy this file to .env and fill in your actual credentials

# Shelly Configuration
SHELLY_API_KEY=your_shelly_api_key_here

# Tapo Configuration
TAPO_USERNAME=your_tapo_username_here
TAPO_PASSWORD=your_tapo_password_here

# Alexa Configuration
ALEXA_ACCESS_TOKEN=your_alexa_access_token_here

# Database Configuration (for future use)
# DATABASE_URL=sqlite:///data/jarvis.db

# API Configuration (for future use)
# API_PORT=8000
# API_HOST=0.0.0.0
# API_SECRET_KEY=your_secret_key_here
